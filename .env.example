# PrintParty — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#

# ── APNs (required) ──────────────────────────────────────────────
# Get these from Apple Developer > Certificates, Identifiers & Profiles > Keys

# Path to your .p8 APNs auth key file (relative to project root)
APNS_KEY_FILE=./relay/AuthKey.p8

# 10-character Key ID shown when you created the key
APNS_KEY_ID=

# Your Apple Developer Team ID
APNS_TEAM_ID=

# ── APNs (optional) ──────────────────────────────────────────────

# App bundle identifier (default: com.clengineering.PrintParty)
# APNS_TOPIC=com.clengineering.PrintParty

# "true" for debug/development builds, "false" for TestFlight/App Store
APNS_SANDBOX=true

# ── Gateway (optional) ───────────────────────────────────────────

# Human-friendly name shown in the iOS app
# GATEWAY_NAME=My PrintParty Gateway

# Comma-separated hostnames / IPs the iOS app can use to pair with this
# gateway. Useful when running in Docker bridge mode where the container
# can't see the host's LAN IP. Auto-detected from network interfaces
# if not set.
# GATEWAY_HOSTS=192.168.1.42,my-server.local

# Relay URL the gateway advertises to iOS clients for remote access.
# Default uses the local relay container. Set to your public relay
# domain for remote access outside the LAN.
# RELAY_URL=https://print.mysticmesh.cloud

# Host port mappings (change if 8080/8090 conflict with other services)
# GATEWAY_PORT=8080
# RELAY_PORT=8090
